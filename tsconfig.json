{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@repo/ui": ["packages/@repo/ui/src"],
      "@repo/core": ["packages/@repo/core/src"],
      "@repo/supabase": ["packages/@repo/supabase/src"],
      "@repo/ai": ["packages/@repo/ai/src"]
    }
  },
  "exclude": ["node_modules", "**/node_modules"],
  "references": [
    { "path": "./apps/web" },
    { "path": "./packages/@repo/ui" },
    { "path": "./packages/@repo/core" },
    { "path": "./packages/@repo/supabase" },
    { "path": "./packages/@repo/ai" }
  ]
}